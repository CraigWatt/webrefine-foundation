{
  "name": "webrefine-foundation",
  "version": "0.1.0",
  "type": "foundation",
  "status": "documentation-first",
  "rendering": {
    "engine": "three.js",
    "reactRenderer": "@react-three/fiber",
    "targets": ["nextjs", "astro"]
  },
  "supportedStarters": ["nextjs", "astro"],
  "paths": {
    "tokens": "./tokens",
    "components": "./components",
    "blocks": "./blocks",
    "templates": "./templates",
    "docs": "./docs"
  },
  "aiGuidance": "./docs/ai-guidance.md",
  "rules": [
    "Prefer simple, composable defaults.",
    "Do not invent undocumented patterns.",
    "Keep starter structure framework-agnostic unless a template says otherwise."
  ]
}
