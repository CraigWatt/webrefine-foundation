---
import { colors, radius, shadow, spacing, typography } from '../../../../tokens';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'WebRefine Starter',
  description = 'A minimal Astro starter with strong type, spacing, and motion defaults.',
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>{`
      :root {
        --wf-bg: ${colors.paper};
        --wf-fg: ${colors.ink};
        --wf-muted: ${colors.inkSoft};
        --wf-line: ${colors.line};
        --wf-accent: ${colors.accent};
        --wf-signal: ${colors.signal};
        --wf-font-sans: ${typography.fontSans};
        --wf-font-serif: ${typography.fontSerif};
        --wf-measure: ${typography.measure};
        --wf-radius: ${radius.lg};
        --wf-shadow: ${shadow.md};
        --wf-space-4: ${spacing[4]};
        --wf-space-6: ${spacing[6]};
        --wf-space-8: ${spacing[8]};
        --wf-space-12: ${spacing[12]};
        --wf-space-16: ${spacing[16]};
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--wf-bg);
        color: var(--wf-fg);
        font-family: var(--wf-font-sans);
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: inherit;
      }
    `}</style>
  </head>
  <body>
    <slot />
  </body>
</html>
